#!/usr/bin/env bash
# update-all — update every package manager and tool in one shot
set -uo pipefail

BOLD='\033[1m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
GREEN='\033[1;32m'
RESET='\033[0m'

failures=()
dnf_upgraded=false

section() {
    echo -e "\n${CYAN}${BOLD}:: $1${RESET}\n"
}

skip() {
    echo -e "${YELLOW}   $1 not found, skipping${RESET}"
}

# ── DNF ──────────────────────────────────────────────────────────────
section "DNF"
if command -v dnf &>/dev/null; then
    _dnf_tmp=$(mktemp)
    sudo dnf upgrade -y --refresh --offline 2>&1 | tee "$_dnf_tmp"
    if [[ ${PIPESTATUS[0]} -eq 0 ]]; then
        grep -qi "Nothing to do" "$_dnf_tmp" || dnf_upgraded=true
    else
        failures+=("DNF")
    fi
    rm -f "$_dnf_tmp"
else
    skip "dnf"
fi

# ── Flatpak ──────────────────────────────────────────────────────────
section "Flatpak"
if command -v flatpak &>/dev/null; then
    flatpak update -y || failures+=("Flatpak")
else
    skip "flatpak"
fi

# ── Homebrew ─────────────────────────────────────────────────────────
section "Homebrew"
if command -v brew &>/dev/null; then
    brew update && brew upgrade || failures+=("Homebrew")
else
    skip "brew"
fi

# ── Oh My Zsh ────────────────────────────────────────────────────────
section "Oh My Zsh"
if [[ -f "${ZSH:-$HOME/.oh-my-zsh}/tools/upgrade.sh" ]]; then
    bash "${ZSH:-$HOME/.oh-my-zsh}/tools/upgrade.sh" || failures+=("Oh My Zsh")
else
    skip "oh-my-zsh"
fi

# ── .NET SDK ───────────────────────────────────────────────────────
section ".NET SDK"
if [[ -x "$HOME/.dotnet/dotnet" ]]; then
    dotnet-update || failures+=(".NET SDK")
else
    skip ".dotnet"
fi

# ── .NET tools ─────────────────────────────────────────────────────
section ".NET tools"
if command -v dotnet &>/dev/null; then
    while read -r tool; do
        dotnet tool update -g "$tool" || failures+=(".NET tool: $tool")
    done < <(dotnet tool list -g | tail -n +3 | awk '{print $1}')
else
    skip "dotnet"
fi

# ── Claude Code ─────────────────────────────────────────────────────
section "Claude Code"
if command -v claude &>/dev/null; then
    claude update || failures+=("Claude Code")
else
    skip "claude"
fi

# ── Neovim plugins ──────────────────────────────────────────────────
section "Neovim plugins"
if command -v nvim &>/dev/null; then
    _nvim_err=$(nvim --headless "+Lazy! sync" +qa 2>&1 >/dev/null)
    if [[ $? -ne 0 ]]; then
        echo "$_nvim_err"
        failures+=("Neovim plugins")
    else
        echo "Done."
    fi
else
    skip "nvim"
fi

# ── Cleanup ──────────────────────────────────────────────────────────
section "Cleanup"
if command -v dnf &>/dev/null; then
    sudo dnf autoremove -y || failures+=("DNF cleanup")
fi
if command -v flatpak &>/dev/null; then
    flatpak uninstall --unused -y || failures+=("Flatpak cleanup")
fi

# ── Summary ──────────────────────────────────────────────────────────
echo ""
if [[ ${#failures[@]} -eq 0 ]]; then
    echo -e "${GREEN}${BOLD}All updates completed successfully.${RESET}"
else
    echo -e "${RED}${BOLD}Failures: ${failures[*]}${RESET}"
    exit 1
fi

if [[ "$dnf_upgraded" == true ]]; then
    echo ""
    echo -e "${YELLOW}${BOLD}DNF packages were staged for offline upgrade.${RESET}"
    sudo dnf5 offline reboot
fi
